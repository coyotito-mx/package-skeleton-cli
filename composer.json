{
    "name": "asciito/skeleton",
    "description": "The skeleton CLI init/bootstrap a package",
    "keywords": [
        "framework",
        "laravel",
        "laravel zero",
        "console",
        "cli"
    ],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Ayax Córdova",
            "email": "ayax.cordova@aydev.mx"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/log": "^12.17",
        "laravel-zero/framework": "^v12.0.2"
    },
    "require-dev": {
        "larastan/larastan": "^v3.7.2",
        "laravel/pint": "v1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ],
        "exclude-from-classmap": [
            "tests/fixtures"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "app:build": "@php skeleton app:build skeleton.phar",
        "cli:build": "phpacker build",
        "build": [
            "@app:build --no-interaction",
            "@cli:build"
        ],
        "test": [
            "@php vendor/bin/pest"
        ],
        "test:ci": "@test --ci",
        "lint": "@php phpstan analyse --memory-limit=1G",
        "style": "@php pint --test",
        "style:fix": "@php pint",
        "refactor": "@php rector --dry-run --memory-limit=1G",
        "refactor:fix": "@php rector --memory-limit=1G",
        "ci:lint": [
            "@lint",
            "@style"
        ],
        "check": [
            "@ci:lint",
            "@refactor"
        ],
        "fix": [
            "@refactor:fix",
            "@style:fix"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": [
        "skeleton"
    ]
}
